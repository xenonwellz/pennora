# Pennora — local development environment
# Copy to .env and fill in values:
#   cp .env.example .env
#
# Generate a secret: openssl rand -base64 32
# See docs/DEPLOYMENT.md for production variables.

# ── Required ──────────────────────────────────────────────────────────────────

# Session signing secret (minimum 32 characters)
BETTER_AUTH_SECRET=replace-with-a-secret-at-least-32-chars-long!!

# Public URL of the app in the browser (Vite dev server)
BETTER_AUTH_URL=http://localhost:5173
APP_URL=http://localhost:5173

# SQLite database file path (relative to apps/server when running locally)
DB_PATH=data.db

# API server port
PORT=3001

# ── Google OAuth (optional) ───────────────────────────────────────────────────
# Enables "Continue with Google" when both variables are set.
# Create credentials at https://console.cloud.google.com/apis/credentials
# Authorized redirect URI: http://localhost:5173/api/auth/callback/google

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ── Email via Resend (optional) ───────────────────────────────────────────────
# Enables password-reset and budget-invite emails when both variables are set.
# https://resend.com

RESEND_API_KEY=
EMAIL_FROM=Pennora <onboarding@resend.dev>
