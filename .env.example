# Core
BETTER_AUTH_SECRET=replace-with-a-secret-at-least-32-chars-long!!
BETTER_AUTH_URL=http://localhost:5173
APP_URL=http://localhost:5173
DB_PATH=data.db
PORT=3001

# Google OAuth (optional — enables "Continue with Google" when both are set)
# Create credentials at https://console.cloud.google.com/apis/credentials
# Authorized redirect URI: http://localhost:5173/api/auth/callback/google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Email via Resend (optional — enables password reset emails and invite emails)
RESEND_API_KEY=
EMAIL_FROM=Peak Finance <onboarding@resend.dev>
