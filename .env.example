# PREFIX=198 — all local ports use this prefix
# API=19801  Web=19802
# Postgres=19832

PORT=19801
DATABASE_URL=postgres://expense:expense@localhost:19832/expense

BETTER_AUTH_URL=http://localhost:19801
APP_URL=http://localhost:19802
# Required — generate with: openssl rand -base64 32
BETTER_AUTH_SECRET=change-me-generate-with-openssl-rand-base64-32

CORS_ORIGINS=http://localhost:19802

# Docker Compose (bun run start) — override the three URLs to the published web port:
# BETTER_AUTH_URL=http://localhost:8080
# APP_URL=http://localhost:8080
# CORS_ORIGINS=http://localhost:8080

# Leave empty in dev — Vite proxy handles API routing
VITE_API_URL=

# Google OAuth (optional)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Email via Resend (optional)
RESEND_API_KEY=
EMAIL_FROM=Pennora <onboarding@resend.dev>
