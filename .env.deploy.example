# Cloudflare API Token (needs D1, R2, Workers, Pages permissions)
CLOUDFLARE_API_TOKEN=

# Cloudflare Account ID
CLOUDFLARE_ACCOUNT_ID=

# Project name (used for D1 database, R2 bucket, Pages project)
PROJECT_NAME=pennora

# D1 Database ID (from `wrangler d1 list` or created during first deploy)
D1_DATABASE_ID=

# Production URLs (must match your custom domain)
BETTER_AUTH_URL=https://pennora.cv
APP_URL=https://pennora.cv
EMAIL_FROM=Pennora <noreply@pennora.cv>

# Secrets (set via wrangler secret put after first deploy)
# BETTER_AUTH_SECRET=
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# RESEND_API_KEY=
