{
  "name": "@expense/server",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "bun --env-file=../../.env run --watch src/index.ts",
    "build": "bun build src/index.ts --outdir dist --target bun",
    "start": "bun run src/index.ts",
    "typecheck": "tsc --noEmit",
    "lint": "oxlint",
    "format:check": "oxfmt --check"
  },
  "exports": {
    "./orpc/*": {
      "types": "./src/orpc/*.ts",
      "default": "./src/orpc/*.ts"
    }
  },
  "dependencies": {
    "@expense/shared": "workspace:*",
    "@orpc/server": "^1.0.0",
    "better-auth": "^1.6.0",
    "drizzle-orm": "^0.45.0",
    "hono": "^4.7.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20250320.0",
    "@types/bun": "^1.3.14",
    "drizzle-kit": "^0.30.0"
  }
}
