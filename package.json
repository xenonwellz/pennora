{
  "name": "expense-tracking",
  "private": true,
  "type": "module",
  "packageManager": "bun@1.3.5",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "docker compose --profile deps up -d && turbo dev",
    "dev:api": "turbo dev --filter=@expense/server",
    "dev:web": "turbo dev --filter=@expense/web",
    "build": "turbo build",
    "db:generate": "turbo db:generate",
    "db:migrate": "turbo db:migrate",
    "db:studio": "turbo db:studio",
    "typecheck": "turbo typecheck",
    "lint": "turbo lint",
    "format": "turbo format",
    "start": "docker compose -f docker-compose.prod.yml up --build -d",
    "stop": "docker compose -f docker-compose.prod.yml down",
    "deploy:api": "wrangler deploy --cwd apps/server",
    "deploy:web": "wrangler pages deploy dist --cwd apps/web",
    "deploy:db": "wrangler d1 migrations apply pennora --remote --cwd apps/server"
  },
  "devDependencies": {
    "turbo": "^2.4.0",
    "typescript": "^5.7.0"
  }
}
