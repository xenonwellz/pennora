{
  "name": "expense-tracking",
  "private": true,
  "packageManager": "bun@1.3.5",
  "workspaces": ["apps/*", "packages/*"],
  "scripts": {
    "dev": "turbo dev",
    "start": "docker compose --env-file .env.docker up --build",
    "start:detach": "docker compose --env-file .env.docker up --build -d",
    "stop": "docker compose down",
    "build": "turbo build",
    "build:docker": "docker compose build",
    "db:generate": "bun run --cwd apps/server drizzle-kit generate",
    "db:push": "bun run --cwd apps/server drizzle-kit push",
    "format": "bun x @biomejs/biome@latest format --write .",
    "format:check": "bun x @biomejs/biome@latest format .",
    "typecheck": "turbo typecheck"
  },
  "devDependencies": {
    "turbo": "^2.4.0",
    "typescript": "^5.7.0"
  }
}
