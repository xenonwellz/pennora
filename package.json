{
  "name": "expense-tracking",
  "private": true,
  "packageManager": "bun@1.3.5",
  "workspaces": ["apps/*", "packages/*"],
  "scripts": {
    "dev": "turbo dev",
    "start": "docker compose --env-file .env.docker up --build",
    "start:detach": "docker compose --env-file .env.docker up --build -d",
    "stop": "docker compose down",
    "build": "turbo build",
    "build:docker": "docker compose build",
    "db:generate": "bun run --cwd apps/server drizzle-kit generate",
    "db:push": "bun run --cwd apps/server drizzle-kit push",
    "format": "bun x @biomejs/biome@latest format --write .",
    "format:check": "bun x @biomejs/biome@latest format .",
    "typecheck": "turbo typecheck",
    "deploy": "./deploy.sh",
    "deploy:api": "./deploy.sh --only api",
    "deploy:web": "./deploy.sh --only web",
    "deploy:db": "./deploy.sh --only db",
    "wrangler:api": "wrangler deploy --config wrangler.worker.toml",
    "wrangler:web": "wrangler pages deploy apps/web/dist --project-name pennora",
    "wrangler:db": "wrangler d1 migrations apply pennora --remote --config wrangler.worker.toml"
  },
  "devDependencies": {
    "turbo": "^2.4.0",
    "typescript": "^5.7.0"
  }
}
